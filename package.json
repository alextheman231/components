{
  "name": "@alextheman/components",
  "version": "7.3.1",
  "description": "A package containing common React components used across my projects.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alextheman231/components.git"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "alextheman",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./DropdownMenu": {
      "types": "./dist/DropdownMenu/index.d.ts",
      "import": "./dist/DropdownMenu/index.js"
    },
    "./QueryBoundary": {
      "types": "./dist/QueryBoundary/index.d.ts",
      "import": "./dist/QueryBoundary/index.js"
    },
    "./Tab": {
      "types": "./dist/Tab/index.d.ts",
      "import": "./dist/Tab/index.js"
    },
    "./audio": {
      "types": "./dist/audio/index.d.ts",
      "import": "./dist/audio/index.js"
    },
    "./file": {
      "types": "./dist/file/index.d.ts",
      "import": "./dist/file/index.js"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "import": "./dist/form/index.js"
    },
    "./routing": {
      "types": "./dist/routing/index.d.ts",
      "import": "./dist/routing/index.js"
    },
    "./snackbar": {
      "types": "./dist/snackbar/index.d.ts",
      "import": "./dist/snackbar/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "create-feature-docs": "storybook build",
    "create-local-package": "pnpm run build && rm -f alextheman-components-*.tgz && pnpm pack",
    "create-release-note": "git pull origin main && bash -c 'alex-c-line template release-note create $@' --",
    "format": "pnpm run format-prettier && pnpm run format-eslint && pnpm run format-markdownlint",
    "format-eslint": "eslint --fix --suppress-all \"{src,stories,tests}/**/*.{ts,tsx}\" \"package.json\" && rm -f eslint-suppressions.json",
    "format-markdownlint": "markdownlint-cli2 --fix \"**/*.md\" \"!{node_modules,dist}/**\" | grep -v \"^Finding:\"",
    "format-prettier": "pnpm run format-prettier-typescript && pnpm run format-prettier-javascript && pnpm run format-prettier-yml",
    "format-prettier-javascript": "prettier --write \"./**/*.{js,json}\"",
    "format-prettier-typescript": "prettier --write --parser typescript \"./**/*.{ts,tsx}\"",
    "format-prettier-yml": "prettier --write \"./**/*.{yml,yaml}\"",
    "lint": "pnpm run lint-tsc && pnpm run lint-eslint && pnpm run lint-markdownlint && pnpm run lint-prettier && pnpm run lint-pre-release",
    "lint-eslint": "eslint \"{src,stories,tests}/**/*.{ts,tsx}\" \"package.json\"",
    "lint-markdownlint": "bash -o pipefail -c 'markdownlint-cli2 \"**/*.md\" \"!{node_modules,dist}/**\"| grep -v \"^Finding:\"'",
    "lint-pre-release": "alex-c-line package-json check --rules no-pre-release-dependencies",
    "lint-prettier": "pnpm run lint-prettier-typescript && pnpm run lint-prettier-javascript && pnpm run lint-prettier-yml",
    "lint-prettier-javascript": "prettier --check \"./**/*.{js,json}\"",
    "lint-prettier-typescript": "prettier --check --parser typescript \"./**/*.{ts,tsx}\"",
    "lint-prettier-yml": "prettier --check \"./**/*.{yml,yaml}\"",
    "lint-tsc": "tsc --noEmit",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "prepare-live-eslint-plugin": "pnpm uninstall @alextheman/eslint-plugin && pnpm install --save-dev @alextheman/eslint-plugin",
    "prepare-live-utility": "pnpm uninstall @alextheman/utility && pnpm install @alextheman/utility",
    "prepare-local-eslint-plugin": "dotenv -e .env -- sh -c 'ESLINT_PLUGIN_PATH=${LOCAL_ESLINT_PLUGIN_PATH:-../eslint-plugin}; pnpm --prefix \"$ESLINT_PLUGIN_PATH\" run build && pnpm uninstall @alextheman/eslint-plugin && pnpm install --save-dev file:\"$ESLINT_PLUGIN_PATH\"'",
    "prepare-local-utility": "dotenv -e .env -- sh -c 'UTILITY_PATH=${LOCAL_UTILITY_PATH:-../utility}; pnpm --prefix \"$UTILITY_PATH\" run build && pnpm uninstall @alextheman/utility && pnpm install file:\"$UTILITY_PATH\"'",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run",
    "test-end-to-end": "playwright test",
    "test-update-ci-snapshots": "docker run --rm -it -v \"$PWD\":/work -v \"$HOME/.pnpm-store\":/pnpm-store -w /work mcr.microsoft.com/playwright:v1.58.2-jammy bash -lc \"npm i -g pnpm@10.29.3 && pnpm config set store-dir /pnpm-store && pnpm install && pnpm test-update-snapshots\"",
    "test-update-snapshots": "playwright test --update-snapshots",
    "update-dependencies": "pnpm update --latest && pnpm update",
    "use-live-eslint-plugin": "pnpm run prepare-live-eslint-plugin && pnpm run lint",
    "use-live-utility": "pnpm run prepare-live-utility",
    "use-local-eslint-plugin": "pnpm run prepare-local-eslint-plugin && pnpm run lint",
    "use-local-utility": "pnpm run prepare-local-utility"
  },
  "dependencies": {
    "@alextheman/utility": "5.21.1",
    "common-tags": "1.8.2",
    "react-icons": "5.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.17.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/material": "9.1.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.4",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-vitest": "10.4.4",
    "@storybook/react-vite": "10.4.4",
    "@tanstack/react-form": "1.33.0",
    "@types/common-tags": "1.8.4",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/types": "8.61.0",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "alex-c-line": "2.10.0",
    "dotenv-cli": "11.0.0",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "eslint-plugin-storybook": "10.4.4",
    "execa": "9.6.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "markdownlint-cli2": "0.22.1",
    "playwright": "1.60.0",
    "prettier": "3.8.4",
    "react": "19.2.7",
    "react-docgen-typescript": "2.4.0",
    "react-dom": "19.2.7",
    "storybook": "10.4.4",
    "styled-components": "6.4.2",
    "tempy": "3.2.0",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8",
    "wouter": "3.10.0"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "@mui/material": ">=7.0.0",
    "@tanstack/react-form": ">=1.28.5",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "wouter": ">=3.9.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "engines": {
    "node": ">=22.0.0"
  }
}
